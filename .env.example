# Multi-Tenant System - Production Environment Variables
# Copy this file to .env.production and fill in your values

# Database Configuration (Use Supabase/Neon.tech URL)
DATABASE_URL=postgresql://user:password@host:port/database

# JWT Configuration (Generate strong secrets)
SECRET_KEY_SUPERADMIN=your_very_long_random_secret_key_here_min_32_chars
SECRET_KEY_TENANT=your_different_very_long_random_secret_key_here_min_32_chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Email Configuration (Gmail or other SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=noreply@yourdomain.com

# CORS Origins (Update with your deployed domain)
ALLOWED_ORIGINS=["https://yourdomain.com","https://www.yourdomain.com"]

# Logging Level
LOG_LEVEL=INFO
